---
import "@/styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Browse published UTDK packages, copy package names, and inspect generated docs.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <meta content={description} name="description" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
