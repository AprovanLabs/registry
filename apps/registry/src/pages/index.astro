---
import { RegistryBrowser } from "@/components/RegistryBrowser";
import { SnippetCarousel } from "@/components/SnippetCarousel";
import { Badge } from "@/components/ui/badge";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getRegistryCatalog } from "@/lib/registry";

const catalog = await getRegistryCatalog();
const updatedAtLabel = catalog.updatedAt
  ? new Date(catalog.updatedAt).toLocaleString("en-US", {
      dateStyle: "medium",
      timeStyle: "short",
    })
  : null;
const providerEntries = catalog.entries.filter((entry) => entry.kind === "provider");
const preferredProviderPaths = ["github", "figma", "openai", "stripe", "slack"];
const featuredEntries = [
  ...preferredProviderPaths
    .map((providerPath) =>
      providerEntries.find((entry) => entry.providerPath === providerPath),
    )
    .filter((entry): entry is (typeof providerEntries)[number] => Boolean(entry)),
  ...providerEntries.slice(0, 4),
]
  .filter(
    (entry, index, entries) =>
      entries.findIndex((candidate) => candidate.providerPath === entry.providerPath) ===
      index,
  )
  .slice(0, 5);

const snippetItems = featuredEntries.map((entry) => {
  if (entry.providerPath === "github") {
    return {
      providerPath: entry.providerPath,
      providerTitle: entry.title,
      iconUrl: entry.openApiIcon,
      code: `import github from '@utdk/github';
await github.users.getByUsername({ username: 'octocat' });`,
    };
  }

  return {
    providerPath: entry.providerPath,
    providerTitle: entry.title,
    iconUrl: entry.openApiIcon,
    code: entry.importSample,
  };
});
---

<BaseLayout title="UTDK Registry">
  <main class="mx-auto flex min-h-screen w-full max-w-7xl flex-col gap-8 px-4 py-8 sm:px-6 lg:px-8">
    <section class="flex flex-col gap-3">
      <div class="flex flex-wrap items-center gap-2">
        <Badge>UTDK Registry</Badge>
        <Badge variant="outline">{catalog.providerCount} providers</Badge>
        <Badge variant="secondary">{catalog.namespaceCount} namespaces</Badge>
        {updatedAtLabel ? <Badge variant="outline">Updated {updatedAtLabel}</Badge> : null}
      </div>
      <h1 class="max-w-3xl text-3xl font-semibold tracking-tight text-balance sm:text-4xl">
        Find the right UTDK provider fast.
      </h1>
    </section>

    <SnippetCarousel client:load items={snippetItems} />

    <section class="flex flex-col gap-4">
      <div class="flex flex-col gap-1">
        <h2 class="text-2xl font-semibold tracking-tight">Packages</h2>
        <p class="text-sm text-muted-foreground">Compact cards with fast filters for provider exploration.</p>
      </div>
      <RegistryBrowser
        client:load
        entries={catalog.entries.map((entry) => ({
          kind: entry.kind,
          providerPath: entry.providerPath,
          packageName: entry.packageName,
          title: entry.title,
          summary: entry.summary,
          parentProviderPath: entry.parentProviderPath,
          docsCount: entry.docs.length + (entry.readmeHtml ? 1 : 0),
          operationCount: entry.operationCount,
          openApiIcon: entry.openApiIcon,
        }))}
      />
    </section>
  </main>
</BaseLayout>
